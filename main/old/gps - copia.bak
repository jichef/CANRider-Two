#include "gps.h"
#include "modem.h"
#include "config.h"
#include "logs.h"
#include <Arduino.h>

extern "C" {
  #include "freertos/FreeRTOS.h"
  #include "freertos/semphr.h"
  #include "freertos/task.h"
  #include "freertos/timers.h"
}

// ==== Hint desde telegram.cpp: cuándo la TelegramTask usa el módem ====
extern "C" bool telegram_using_modem();

// --- Forward para poder notificar por Telegram desde aquí
bool telegramSend(const String& msg);   // definida en telegram.cpp

// ===== Configuración =====
#define GNSS_USE_URC 1            // activar URCs para recibir $GSV/$GSA
// #define GPS_DEBUG_CGNSINF 1

// === LED: usar GPIO 12 del ESP32, activo en LOW ===
#undef  GPS_LED_USE_SGPIO
#define GPS_LED_PIN 12
#define GPS_LED_ACTIVE_LOW 1

// ===== Forward de modemLock/modemUnlock (las implementas en otro módulo)
bool modemLock(const char* tag, uint32_t ms);
void modemUnlock(const char* tag);

// ===== Estado de GPS para /gps (temporizado) =====
static volatile bool s_gpsActive   = false;   // GNSS encendido
static volatile bool s_timerMode   = false;   // GNSS por temporizador (/gps)
static TimerHandle_t s_gpsTimer    = nullptr;

// ===== Estado: intento de FIX en curso =====
static volatile bool s_fixInProgress = false;
bool gpsFixInProgress() { return s_fixInProgress; }

// ===== Abort inmediato del intento de fix =====
static volatile bool s_abortReq = false;
void gpsRequestAbort() { s_abortReq = true; }   // C++ linkage (coincide con gps.h)

// ===== Helpers =====

// Arbitraje: intenta tomar el lock en rebanadas cortas y cede si Telegram usa el módem
static bool lockWithArbitration(const char* tag, uint32_t total_ms, uint32_t slice_ms) {
  unsigned long t0 = millis();
  while (millis() - t0 < total_ms) {
    if (telegram_using_modem()) { vTaskDelay(pdMS_TO_TICKS(80)); continue; }
    if (modemLock(tag, slice_ms)) return true;
    vTaskDelay(pdMS_TO_TICKS(50));
  }
  return false;
}

// --- LED del GNSS por GPIO local ---
static void gpsLedSet(bool on) {
#if defined(GPS_LED_PIN)
  static bool inited = false;
  if (!inited) {
    pinMode(GPS_LED_PIN, OUTPUT);
  #ifdef GPS_LED_ACTIVE_LOW
    digitalWrite(GPS_LED_PIN, HIGH); // apagado
  #else
    digitalWrite(GPS_LED_PIN, LOW);  // apagado
  #endif
    inited = true;
  }
  #ifdef GPS_LED_ACTIVE_LOW
    digitalWrite(GPS_LED_PIN, on ? LOW : HIGH);
  #else
    digitalWrite(GPS_LED_PIN, on ? HIGH : LOW);
  #endif
  logMsg(LOG_INFO, "GPS_LED", String("GPIO ") + GPS_LED_PIN + " -> " + (on ? "ON" : "OFF"));
#else
  (void)on;
#endif
}

// Control centralizado de URCs (no-op si GNSS_USE_URC == 0)
static bool gnss_urc_enabled = false;
static void gnssSetURC(bool enable) {
#if GNSS_USE_URC
  if (gnss_urc_enabled == enable) return;
  if (!lockWithArbitration("GPS_URC", 600, 300)) {
    logMsg(LOG_DEBUG, "MUTEX", "GPS no pudo tomar el mutex (URC)");
    return;
  }
  modem.sendAT(String("+CGNSURC=") + (enable ? "1" : "0"));
  modem.waitResponse(200);
  modemUnlock("GPS_URC");
  gnss_urc_enabled = enable;
#else
  (void)enable;
#endif
}

// --- Nudges: constelaciones + warm/cold start ---
static void gnssEnsureConstellations() {
  if (!lockWithArbitration("GPS_CFG", 1500, 300)) return;
  // Formato SIM7000: AT+CGNSMOD=<gps>,<glo>,<bd>,<gal>  (0=off, 1=on)
  modem.sendAT("+CGNSMOD=1,1,1,1"); modem.waitResponse(800);   // GPS+GLONASS+BeiDou+Galileo
  modem.sendAT("+CGNSHOT");          modem.waitResponse(500);   // hot start (si soporta)
  modemUnlock("GPS_CFG");
  logMsg(LOG_INFO, "GPS", "Constelaciones GNSS habilitadas (GPS/GLO/BD/GAL)");
}

static void gnssWarmStart() {
  if (!lockWithArbitration("GNSS_WARM", 3000, 300)) return;
  modem.sendAT("+CGNSPWR=0"); modem.waitResponse(2000);
  modem.sendAT("+CGNSPWR=1"); modem.waitResponse(5000);
  modem.sendAT("+CGNSURC=0"); modem.waitResponse(200);
  modemUnlock("GNSS_WARM");
  logMsg(LOG_INFO, "GPS", "Warm restart GNSS");
}

static void gnssColdStart() {
  if (!lockWithArbitration("GNSS_COLD", 5000, 300)) return;
  modem.sendAT("+CGNSCOLD");  modem.waitResponse(3000); // si no existe, lo ignora
  modem.sendAT("+CGNSPWR=0"); modem.waitResponse(2000);
  modem.sendAT("+CGNSPWR=1"); modem.waitResponse(5000);
  modem.sendAT("+CGNSURC=0"); modem.waitResponse(200);
  modemUnlock("GNSS_COLD");
  logMsg(LOG_WARN, "GPS", "Cold restart GNSS");
}

// Encendido/apagado de GNSS de forma segura (locks cortos)
static bool powerOnGPS() {
  if (!lockWithArbitration("GPS_PWR", 1200, 300)) {
    logMsg(LOG_DEBUG, "MUTEX", "GPS no pudo tomar el mutex (power ON)");
    return false;
  }

  // Algunas placas (p. ej. T-SIM7000G) necesitan habilitar LNA/ANT por SGPIO
  modem.sendAT("+SGPIO=0,4,1,1"); modem.waitResponse(500);

  modem.sendAT("+CGNSPWR=1"); modem.waitResponse(600);

  // Garantiza constelaciones activas
  gnssEnsureConstellations();

  modem.sendAT("+CGNSSEQ=\"RMC,GSV,GSA\""); modem.waitResponse(400);
  modem.sendAT("+CGNSURC=0");               modem.waitResponse(200);

  modemUnlock("GPS_PWR");

  gnssSetURC(false);
  s_gpsActive = true;
  s_abortReq  = false;     // limpiar cualquier abort previo
  gpsLedSet(true);         // LED ON
  logMsg(LOG_INFO, "GPS", "GNSS encendido");
  return true;
}

void powerOffGPS() {
  for (int i=0; i<5 && telegram_using_modem(); ++i) vTaskDelay(pdMS_TO_TICKS(120));

  if (!lockWithArbitration("GPS_PWR", 900, 300)) {
    logMsg(LOG_DEBUG, "MUTEX", "GPS no pudo tomar el mutex (power OFF)");
    return;
  }
  modem.sendAT("+CGNSPWR=0"); modem.waitResponse(300);
  modemUnlock("GPS_PWR");
  s_gpsActive = false;
  s_timerMode = false;
  s_fixInProgress = false;     // asegurar estado coherente
  gpsLedSet(false);            // LED OFF
  logMsg(LOG_INFO, "GPS", "Power OFF solicitado");
}

// Timer callback para apagado programado
static void gpsOffTimerCb(TimerHandle_t) {
  logMsg(LOG_INFO, "GPS", "Timer expirado: apagando GNSS");
  powerOffGPS();
}

// -------------------- PARSEO ROBUSTO CGNSINF+NMEA ---------------------

// Extrae nº sats en vista desde un $..GSV (campo 3)
static void parseGSV_Count(const String& nmea, int& sats_view_max) {
  // $GxGSV,total_msgs,msg_idx,sv_in_view, ...
  int firstComma = nmea.indexOf(',');
  if (firstComma < 0) return;
  int c = 0, start = 0, sv_in_view = -1;
  for (int i = 0; i < (int)nmea.length(); ++i) {
    if (nmea[i] == ',' || nmea[i] == '*') {
      String f = nmea.substring(start, i);
      f.trim();
      ++c;
      if (c == 3) { // campo 3 = sv_in_view
        if (f.length()) sv_in_view = f.toInt();
        break;
      }
      start = i + 1;
    }
  }
  if (sv_in_view > sats_view_max) sats_view_max = sv_in_view;
}

// Cuenta PRNs usados en $..GSA (campos 4..15)
static void parseGSA_Used(const String& nmea, int& sats_used) {
  // $GxGSA,mode,fix,prn1..prn12,PDOP,HDOP,VDOP
  int field = 0, start = 0, count = 0;
  for (int i = 0; i < (int)nmea.length(); ++i) {
    if (nmea[i] == ',' || nmea[i] == '*') {
      ++field;
      if (field >= 4 && field <= 15) { // 12 posibles PRNs
        String prn = nmea.substring(start, i); prn.trim();
        if (prn.length()) ++count;
      }
      start = i + 1;
      if (nmea[i] == '*') break;
    }
  }
  if (count > sats_used) sats_used = count;
}

// Extrae HDOP aproximado desde $..GSA (campo PDOP,HDOP,VDOP → HDOP es penúltimo)
static void parseGSA_HDOP(const String& nmea, float& hdop_out) {
  int star = nmea.indexOf('*');
  String core = (star > 0 ? nmea.substring(0, star) : nmea);
  int last = core.lastIndexOf(',');
  if (last < 0) return;
  int prev = core.lastIndexOf(',', last - 1);
  if (prev < 0) return;
  String hd = core.substring(prev + 1, last);
  hd.trim();
  if (hd.length()) {
    float v = hd.toFloat();
    if (v > 0.0f) hdop_out = v;
  }
}

// Lee +CGNSINF y, además, aprovecha NMEA anexas para obtener sats/hdop
// Ventana de lectura corta para no pelear con Telegram
static bool readCGNSINF_ShortLocked(String &lat, String &lon,
                                    int &sats_used, int &sats_view, float &hdop_out) {
  sats_used = -1; sats_view = -1; hdop_out = -1.0f;
  lat = ""; lon = "";

  if (!lockWithArbitration("GPS_INF", 800, 300)) {
    logMsg(LOG_DEBUG, "MUTEX", "GPS no pudo tomar el mutex (INF)");
    return false;
  }

  modem.sendAT("+CGNSINF");
  unsigned long t0 = millis();
  bool gotFixLine = false;
  bool gotOK = false;

  // Acumuladores por si vienen varias GSV/GSA
  int view_max = -1;
  int used_max = -1;
  float gsa_hdop = -1.0f;

  uint16_t win_ms = 500;
#if GNSS_USE_URC
  win_ms = 1200;   // deja respirar a los $GSA/$GSV por el puerto AT
#endif

  while (millis() - t0 < win_ms) {
    if (s_abortReq) break;
    if (!modem.stream.available()) { vTaskDelay(1); continue; }
    String line = modem.stream.readStringUntil('\n');
    line.trim();

#ifdef GPS_DEBUG_CGNSINF
    if (line.length()) Serial.println(line);
#endif

    if (line.startsWith("+CGNSINF:")) {
      int idx = line.indexOf(':');
      String payload = (idx >= 0) ? line.substring(idx + 1) : line;
      payload.trim();

      const int MAX_TOK = 24;
      String tok[MAX_TOK];
      int ti = 0, start = 0;
      for (int i = 0; i < payload.length() && ti < (MAX_TOK - 1); ++i) {
        if (payload[i] == ',') {
          tok[ti++] = payload.substring(start, i);
          start = i + 1;
        }
      }
      tok[ti++] = payload.substring(start);

      if (ti >= 5) {
        String fix  = tok[1]; fix.trim();
        String sLat = tok[3]; sLat.trim();
        String sLon = tok[4]; sLon.trim();
        if (ti >= 11 && tok[10].length()) hdop_out  = tok[10].toFloat();

        if (ti >= 15 && tok[14].length()) {
          int v14 = (int)tok[14].toInt();
          if (v14 > view_max) view_max = v14;
        }
        if (ti >= 16 && tok[15].length()) {
          int v15 = (int)tok[15].toInt();
          if (v15 > used_max) used_max = v15;
        }

        if (fix == "1" && sLat.length() && sLon.length()
            && sLat != "0.000000" && sLon != "0.000000") {
          lat = sLat; lon = sLon;
          gotFixLine = true;
        }
      }
    } else if (line.startsWith("$GPGSV") || line.startsWith("$GLGSV") ||
               line.startsWith("$GAGSV") || line.startsWith("$GBGSV") ||
               line.startsWith("$GNGSV")) {
      parseGSV_Count(line, view_max);
    } else if (line.startsWith("$GPGSA") || line.startsWith("$GNGSA") ||
               line.startsWith("$GLGSA") || line.startsWith("$GAGSA") ||
               line.startsWith("$GBGSA")) {
      parseGSA_Used(line, used_max);
      parseGSA_HDOP(line, gsa_hdop);
    } else if (line == "OK") {
      gotOK = true;
      break;
    } else if (line == "ERROR") {
      break;
    }
  }

  modemUnlock("GPS_INF");

  // Consolidar métricas
  if (hdop_out < 0.0f && gsa_hdop > 0.0f) hdop_out = gsa_hdop;
  if (view_max >= 0) sats_view = view_max;  else if (sats_view < 0) sats_view = 0;
  if (used_max >= 0) sats_used = used_max;  else if (sats_used < 0) sats_used = 0;

  // Devolvemos si hay posición válida; pero las métricas quedan actualizadas
  return gotFixLine && gotOK;
}

// Fallback por red (CLBS) con lock por bloques cortos y reintentos
static bool getApproxLocationCLBS_ShortLocked(String &lat, String &lon, int &acc_m, unsigned long timeout_ms=15000) {
  acc_m = -1; lat = ""; lon = "";
  unsigned long t0 = millis();
  bool sent = false;

  while (millis() - t0 < timeout_ms) {
    if (s_abortReq) return false;
    if (!lockWithArbitration("GPS_CLBS", 900, 300)) {
      vTaskDelay(pdMS_TO_TICKS(50));
      continue;
    }

    if (!sent) {
      modem.sendAT("+CLBS=1,1");
      sent = true;
    }

    bool done = false;
    unsigned long w0 = millis();
    while (millis() - w0 < 400) {
      if (s_abortReq) { done = true; break; }
      if (!modem.stream.available()) { vTaskDelay(1); continue; }
      String line = modem.stream.readStringUntil('\n');
      line.trim();

      if (line.startsWith("+CLBS:")) {
        int colon = line.indexOf(':');
        String payload = (colon>=0) ? line.substring(colon+1) : line;
        payload.trim();
        String tok[6]; int ti=0, s=0;
        for (int i=0; i<payload.length() && ti<5; ++i) {
          if (payload[i]==',') { tok[ti++]=payload.substring(s,i); s=i+1; }
        }
        tok[ti++] = payload.substring(s);
        if (ti >= 4) {
          int err = tok[0].toInt();
          if (err == 0) {
            String a = tok[1]; a.trim();
            String b = tok[2]; b.trim();
            int acc  = tok[3].toInt();
            float va = a.toFloat();
            float vb = b.toFloat();
            bool a_is_lat = (va >= -90.0f && va <= 90.0f);
            bool b_is_lon = (vb >= -180.0f && vb <= 180.0f);
            if (a_is_lat && b_is_lon) { lat=a; lon=b; }
            else { lat=b; lon=a; }
            acc_m = (acc > 0 ? acc : -1);
            modemUnlock("GPS_CLBS");
            return (lat.length() && lon.length());
          }
        }
        done = true;
      } else if (line == "ERROR") {
        done = true;
      }
    }

    modemUnlock("GPS_CLBS");
    if (done) break;
    vTaskDelay(pdMS_TO_TICKS(120));
  }
  return false;
}

// ===== API =====

// Arranca GNSS por un tiempo determinado (p. ej., /gps = 10 min).
// Si ya estaba activo, renueva el tiempo.
bool gpsStartFor(uint32_t ms) {
  if (!s_gpsTimer) {
    s_gpsTimer = xTimerCreate("gps_kill", pdMS_TO_TICKS(ms), pdFALSE, nullptr, gpsOffTimerCb);
    if (!s_gpsTimer) {
      logMsg(LOG_WARN, "GPS", "No se pudo crear el timer GNSS");
      return false;
    }
  }

  if (!s_gpsActive) {
    if (!powerOnGPS()) {
      logMsg(LOG_WARN, "GPS", "Fallo al encender GNSS");
      return false;
    }
  }

  s_abortReq = false;  // limpiar abort al (re)iniciar
  s_timerMode = true;
  xTimerStop(s_gpsTimer, 0);
  xTimerChangePeriod(s_gpsTimer, pdMS_TO_TICKS(ms), 0);
  xTimerStart(s_gpsTimer, 0);

  logMsg(LOG_INFO, "GPS", String("GNSS activo por ") + (ms/1000) + " s");
  return true;
}

// Apaga GNSS inmediatamente y cancela temporizador
void gpsKill() {
  if (s_gpsTimer) xTimerStop(s_gpsTimer, 0);
  s_abortReq = true;         // por si alguien está en mitad de obtenerGPS()
  s_fixInProgress = false;
  powerOffGPS();
  logMsg(LOG_INFO, "GPS", "gpsKill(): GNSS detenido");
}

// Indica si GNSS está encendido
bool gpsActive() { return s_gpsActive; }

bool obtenerGPS(String &respuesta,
                unsigned long timeout_ms,
                GpsProgressCb progress_cb,
                void* progress_ctx,
                uint16_t progress_step_s) {
  respuesta = "";

  logMark("GPS_ON");
  startWindow("GPS_FIX_SEARCH");
  logMsg(LOG_INFO, "GPS", String("Arrancando GNSS; timeout_s=") + String((timeout_ms+500)/1000));

  if (!s_gpsActive) {
    if (!powerOnGPS()) {
      endWindow("GPS_FIX_SEARCH");
      logMsg(LOG_WARN, "GPS", "No se pudo encender GNSS");
      return false;
    }
  } else {
    gnssSetURC(false);
  }

  String lat, lon;
  bool got = false;
  unsigned long start = millis();
  uint16_t total_s = (timeout_ms + 500) / 1000;
  uint16_t last_notified_s = 0;

  int   last_sats_used = 0, last_sats_view = 0;
  float last_hdop      = -1.0f;

#if GNSS_USE_URC
  gnssSetURC(true);
#endif

  s_fixInProgress = true;

  while (!s_abortReq && (millis() - start < timeout_ms) && !got) {
    int su=0, sv=0; float hd=-1.0f;
    String tlat, tlon;
    bool fixNow = readCGNSINF_ShortLocked(tlat, tlon, su, sv, hd);

    // Actualiza métricas si llegaron
    if (su > 0) last_sats_used = su;
    if (sv > 0) last_sats_view = sv;
    if (hd >= 0) last_hdop = hd;

    if (fixNow) { lat = tlat; lon = tlon; got = true; }

    uint16_t elapsed_s = (millis() - start + 500) / 1000;

    // --- Escalado automático si no hay FIX ---
    if (!got && elapsed_s == 180 && last_sats_used == 0) {   // ~3 min
      if (last_sats_view >= 8) gnssWarmStart();              // ve satélites pero no usa
    }
    if (!got && elapsed_s == 360 && last_sats_used == 0) {   // ~6 min
      gnssColdStart();
    }
    if (!got && elapsed_s == 540 && last_sats_used == 0) {   // ~9 min
      telegramSend("🛰️ Sigue sin FIX tras 9 min. Prueba exterior y base metálica bajo la antena.");
    }

    if (!s_abortReq && progress_cb &&
        progress_step_s > 0 &&
        elapsed_s >= last_notified_s + progress_step_s &&
        elapsed_s < total_s) {
      last_notified_s = elapsed_s;
      progress_cb(progress_ctx, elapsed_s, total_s, last_sats_used, last_sats_view);
      logMsg(LOG_DEBUG, "GPS",
             String("progreso: ") + elapsed_s + "/" + total_s +
             "s, sats_used=" + String(last_sats_used) +
             ", sats_view=" + String(last_sats_view));
    }

    vTaskDelay(pdMS_TO_TICKS(800));
  }

  bool aborted = s_abortReq;
  s_abortReq = false;

  String approx_lat, approx_lon;
  int approx_acc = -1;
  bool approx_ok = false;

  if (!aborted && got) {
    endWindow("GPS_FIX_SEARCH");
    logMsg(LOG_INFO, "GPS", String("FIX OK; sats_used=") +
                      String(last_sats_used) +
                      " sats_view=" + String(last_sats_view) +
                      (last_hdop>=0? String(" hdop=")+String(last_hdop,1):""));

    respuesta  = "📍 Ubicación: https://maps.google.com/?q=" + lat + "," + lon;
    respuesta += "\n🛰️ Satélites: " + String(last_sats_used) +
                 " usados / " + String(last_sats_view) + " en vista";
    if (last_hdop >= 0) respuesta += "\n🎯 HDOP: " + String(last_hdop, 1);

    // Al encontrar FIX, apagar GNSS aunque esté en modo temporizado
    if (s_gpsTimer) xTimerStop(s_gpsTimer, 0);
    s_timerMode = false;
    powerOffGPS();
    logMark("GPS_OFF");

  } else if (!aborted) {
    endWindow("GPS_FIX_SEARCH");

    startWindow("GPS_CLBS");
    logMsg(LOG_WARN, "GPS", "Sin FIX en timeout; intentando CLBS…");
    approx_ok = getApproxLocationCLBS_ShortLocked(approx_lat, approx_lon, approx_acc, 15000);
    endWindow("GPS_CLBS");

    if (approx_ok) {
      logMsg(LOG_INFO, "GPS", String("CLBS OK; acc≈") + (approx_acc>0?String(approx_acc):"N/A") + " m");
      respuesta  = "📍 Ubicación (aprox.): https://maps.google.com/?q=" + approx_lat + "," + approx_lon;
      if (approx_acc > 0) respuesta += "\n±" + String(approx_acc) + " m";
      respuesta += "\nℹ️ Sin fix GNSS en " + String(total_s) + " s; posición por red móvil.";
      if (!s_timerMode) { powerOffGPS(); logMark("GPS_OFF"); }
    } else {
      logMsg(LOG_WARN, "GPS", "CLBS falló; no se pudo obtener ubicación");
      respuesta = "❌ No he podido obtener fix en " + String(total_s) +
                  " s. Inténtalo al aire libre.";
      if (!s_timerMode) { powerOffGPS(); logMark("GPS_OFF"); }
    }
  } else {
    endWindow("GPS_FIX_SEARCH");
    logMsg(LOG_INFO, "GPS", "Intento de FIX abortado por solicitud");
    powerOffGPS();
    logMark("GPS_OFF");
  }

  s_fixInProgress = false;   // aseguramos flag al salir
  return (!aborted) && (got || approx_ok);
}

void checkGPSStatus(unsigned long /*now*/) {
  // No-op
}
